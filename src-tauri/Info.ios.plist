<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Must match the .appiconset name. -->
  <key>CFBundleIconName</key>
  <string>AppIcon</string>
  <key>NSLocalNetworkUsageDescription</key>
  <string>Rimokon Miru finds and controls your Roku over your local Wi-Fi.</string>
  <key>NSCameraUsageDescription</key>
  <string>Rimokon Miru uses the camera only if you take a photo to set as your app background.</string>
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>
  <!-- Permits plain HTTP to the Roku's LAN address without disabling ATS globally. -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsLocalNetworking</key>
    <true/>
  </dict>
</dict>
</plist>
