{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rimokon Miru",
  "version": "0.22.0",
  "identifier": "dev.brainerd.rimokonmiru",
  "build": {
    "beforeDevCommand": "pnpm ui:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm ui:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rimokon Miru",
        "width": 420,
        "height": 800,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Watch tracker and Roku remote",
    "iOS": {
      "developmentTeam": "V6J999TY63",
      "minimumSystemVersion": "14.0"
    }
  }
}
